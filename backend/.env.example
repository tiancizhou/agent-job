# QuickApp 后端配置模板
#
# 使用方式：
# 1. 复制本文件为 backend/.env
# 2. 按实际环境修改下面的值
# 3. 使用 backend/start.sh 或根目录 update-start.sh 启动时会自动读取 backend/.env
#
# 注意：不要把包含真实密钥的 backend/.env 提交到代码仓库。

# LLM_API_KEY
# 大模型服务的 API Key。
# 这是必填项，后端启动时会读取它来调用 OpenAI 兼容的 /chat/completions 接口。
# 示例：sk-xxxxxxxxxxxxxxxxxxxxxxxx
LLM_API_KEY=replace-with-your-api-key

# LLM_BASE_URL
# OpenAI 兼容接口的基础地址，不要包含 /chat/completions。
# 后端会自动拼接为：${LLM_BASE_URL}/chat/completions
# 示例：
# - OpenAI 官方兼容地址：https://api.openai.com/v1
# - DeepSeek 兼容地址：https://api.deepseek.com/v1
# - 自建或代理服务：https://your-llm-gateway.example.com/v1
LLM_BASE_URL=https://example.com/v1

# LLM_MODEL
# 生成应用时使用的大模型名称。
# 需要与你的 LLM_BASE_URL 服务支持的模型 ID 一致。
# 示例：gpt-4.1、deepseek-chat、claude-sonnet-4-6、你的代理模型名等。
LLM_MODEL=replace-with-model-name

# SERVER_PORT
# 后端 HTTP 服务监听端口。
# backend/start.sh 会优先使用环境变量 SERVER_PORT，未配置时默认 8000。
# 示例：8000、9000。
SERVER_PORT=8000

# DATA_DIR
# QuickApp 运行数据目录。
# 生成的应用文件会保存到 ${DATA_DIR}/apps 下，并通过后端静态服务对外提供预览。
# 默认 ./data 是相对于 backend 目录的路径。
# 示例：./data、/var/lib/quickapp/data。
DATA_DIR=./data

# DATABASE_URL
# 数据库连接地址。
# 默认使用 SQLite，适合单机、小团队或开发测试。
# 如果后续需要更高并发或商业化部署，建议切换 PostgreSQL。
#
# SQLite 示例：
# DATABASE_URL=sqlite:///./quickapp.db
#
# PostgreSQL 示例：
# DATABASE_URL=postgresql+psycopg://quickapp_user:quickapp_password@127.0.0.1:5432/quickapp
DATABASE_URL=sqlite:///./quickapp.db

# GENERATION_MAX_CONCURRENT
# 应用生成的全局并发上限。
# 用于保护服务器和 LLM API，避免大量用户同时生成时把系统或模型服务打满。
# 超过上限时，前端会提示“当前生成任务较多，请稍后再试”。
# 建议：
# - 本地开发：2-3
# - 小团队测试：5-10
# - 较高配置服务器：根据 LLM 限流、CPU、内存和数据库能力逐步调大
GENERATION_MAX_CONCURRENT=10
